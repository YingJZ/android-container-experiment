<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#1a1a2e">

    <!-- 标题 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Binder 句柄测试"
        android:textSize="24sp"
        android:textColor="#e94560"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="容器快照恢复实验"
        android:textSize="14sp"
        android:textColor="#888888"
        android:gravity="center"
        android:paddingBottom="16dp" />

    <!-- 状态卡片 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#16213e"
        android:padding="16dp"
        android:orientation="vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="当前状态"
            android:textSize="12sp"
            android:textColor="#888888" />

        <TextView
            android:id="@+id/statusTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="初始化中..."
            android:textSize="18sp"
            android:textColor="#0f3460"
            android:textStyle="bold"
            android:paddingTop="4dp" />

    </LinearLayout>

    <!-- 控制按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/startTestButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="开始周期测试"
            android:textColor="#ffffff"
            android:backgroundTint="#4caf50"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/stopTestButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="停止"
            android:textColor="#ffffff"
            android:backgroundTint="#f44336"
            android:enabled="false"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/singleTestButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="单次测试"
            android:textColor="#ffffff"
            android:backgroundTint="#2196f3"
            android:layout_marginStart="4dp" />

    </LinearLayout>

    <!-- 日志区域 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="测试日志"
        android:textSize="14sp"
        android:textColor="#888888"
        android:paddingBottom="8dp" />

    <ScrollView
        android:id="@+id/logScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#0f0f23"
        android:padding="8dp">

        <TextView
            android:id="@+id/logTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="#00ff00"
            android:fontFamily="monospace"
            android:text="" />

    </ScrollView>

    <!-- 底部说明 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="提示: 在容器快照恢复后观察日志中的 DeadObjectException"
        android:textSize="11sp"
        android:textColor="#666666"
        android:gravity="center"
        android:paddingTop="8dp" />

</LinearLayout>
